<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TravelCompanion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TravelCompanion"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Title="TravelCompanion">

    <TabBar x:Name="RootBar">
        <ShellContent Title="Image" Icon="image"
                      ContentTemplate="{DataTemplate local:ImageAnalysisPage}" />
        <ShellContent Title="NLP" Icon="speaker.png"
                      ContentTemplate="{DataTemplate local:NaturalLanguagePage}" />
        <ShellContent Title="Chat" Icon="microphone.png"
                      ContentTemplate="{DataTemplate local:ChatbotPage}" />
        <ShellContent Title="Search" Icon="search.png"
                      ContentTemplate="{DataTemplate local:SearchPage}" />
        <ShellContent Title="Docs" Icon="document.png"
                      ContentTemplate="{DataTemplate local:DocProcessorPage}" />
        <!--<ShellContent Title="Maps" Icon="map.png"
                      ContentTemplate="{DataTemplate local:MapsPage}" />-->

    </TabBar>
</Shell>
